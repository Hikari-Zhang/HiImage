# ============================================================
# HiImage - .gitattributes
# ============================================================

# =====================
# 自动归一化行尾（仅文本文件）
# =====================
* text=auto

# =====================
# 语言/源代码：强制 LF（跨平台协作）
# =====================
*.js      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.jsx     text eol=lf
*.json    text eol=lf
*.lock    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.toml    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.py      text eol=lf
*.sh      text eol=lf
*.bat     text eol=lf
*.ps1     text eol=lf
*.svg     text eol=lf
*.xml     text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.less    text eol=lf

# Windows 专用文件保留 CRLF
*.sln     text eol=crlf
*.vcxproj text eol=crlf
*.csproj  text eol=crlf

# =====================
# 二进制文件（不合并、不 diff）
# =====================
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.bmp  binary
*.webp binary
*.tiff binary
*.ico  binary
*.icns binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
*.eot  binary
*.mp4  binary
*.webm binary
*.mp3  binary
*.wav  binary
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.7z   binary
*.rar  binary
*.pyc  binary
*.pyd  binary
*.whl  binary

# ML 模型权重（大文件，Git LFS 建议）
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.bin         filter=lfs diff=lfs merge=lfs -text
*.ckpt        filter=lfs diff=lfs merge=lfs -text
*.pth         filter=lfs diff=lfs merge=lfs -text
*.pt          filter=lfs diff=lfs merge=lfs -text
*.onnx        filter=lfs diff=lfs merge=lfs -text

# =====================
# 需生成导出归档时排除的文件
# =====================
.gitattributes export-ignore
.gitignore     export-ignore
.env*          export-ignore
*.log          export-ignore

# =====================
# 编码声明（PowerShell/Windows 脚本）
# =====================
*.ps1   working-tree-encoding=UTF-8
*.bat   working-tree-encoding=UTF-8
